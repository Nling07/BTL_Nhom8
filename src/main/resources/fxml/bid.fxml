<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="501.0" prefWidth="926.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.btl.n8.Controller.bidController">
   <children>

      <!-- Background -->
      <ImageView fitHeight="533.0" fitWidth="968.0" layoutY="-1.0"
                 mouseTransparent="true" pickOnBounds="true" preserveRatio="true"
                 AnchorPane.rightAnchor="-6.0">
         <image><Image url="@../images/bidhome.png"/></image>
      </ImageView>

      <!-- Title -->
      <Label layoutX="30.0" layoutY="18.0" text="Auction Items" textFill="WHITE">
         <font><Font name="Press Start 2P" size="18.0"/></font>
      </Label>

      <!-- Return button -->
      <Button layoutX="820.0" layoutY="15.0"
              prefWidth="90.0" prefHeight="30.0"
              text="← Return" onAction="#Return"/>

      <!-- Search field -->
      <TextField fx:id="searchField"
                 layoutX="30.0" layoutY="65.0"
                 prefWidth="300.0" prefHeight="34.0"
                 promptText="Search by Item ID..."/>

      <!-- Search button -->
      <Button fx:id="searchButton"
              layoutX="340.0" layoutY="65.0"
              prefWidth="90.0" prefHeight="34.0"
              text="Search" onAction="#handleSearch"/>

      <!-- TableView -->
      <TableView fx:id="itemTable"
                 layoutX="30.0" layoutY="115.0"
                 prefWidth="866.0" prefHeight="360.0">
         <columns>
            <TableColumn fx:id="colId"      text="Item ID"       prefWidth="80.0"/>
            <TableColumn fx:id="colName"    text="Item Name"     prefWidth="280.0"/>
            <TableColumn fx:id="colType"    text="Type"          prefWidth="100.0"/>
            <TableColumn fx:id="colPrice"   text="Current Price" prefWidth="150.0"/>
            <TableColumn fx:id="colStatus"  text="Status"        prefWidth="110.0"/>
            <TableColumn fx:id="colAction"  text="Action"        prefWidth="100.0"/>
         </columns>
      </TableView>

   </children>
</AnchorPane>