<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.btl.n8.Controller.AutoBidController"
      prefWidth="480.0"
      style="-fx-background-color: #0d1b2a; -fx-background-radius: 10; -fx-border-color: #1a3a5c; -fx-border-radius: 10; -fx-border-width: 1;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-padding: 14 18 14 18; -fx-border-color: #1a3a5c; -fx-border-width: 0 0 1 0; -fx-background-color: #0a1628; -fx-background-radius: 10 10 0 0;">
        <Label text="&#x26A1;" style="-fx-font-size: 18px;"/>
        <Label text="Auto Bid" textFill="#00ff88">
            <font><Font name="Press Start 2P" size="13.0"/></font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusBadge" text="OFF"
               style="-fx-background-color: #333a4a; -fx-text-fill: #888; -fx-padding: 3 10 3 10; -fx-background-radius: 99;">
            <font><Font name="Press Start 2P" size="7.0"/></font>
        </Label>
        <Button fx:id="closeBtn" text="&#x2715;" onAction="#handleClose"
                style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 16px; -fx-cursor: hand; -fx-text-fill: #00ff88;"/>
    </HBox>

    <!-- Item info bar -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-padding: 10 18 10 18; -fx-background-color: #0f2035;">
        <Label text="Item" textFill="#7ecfff">
            <font><Font name="Press Start 2P" size="7.0"/></font>
        </Label>
        <Label fx:id="lblItemName" text="-" textFill="#ffd700">
            <font><Font name="Press Start 2P" size="8.0"/></font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Current" textFill="#7ecfff">
            <font><Font name="Press Start 2P" size="7.0"/></font>
        </Label>
        <Label fx:id="lblCurrentPrice" text="-" textFill="#ffd700">
            <font><Font name="Press Start 2P" size="8.0"/></font>
        </Label>
    </HBox>

    <Separator style="-fx-background-color: #1a3a5c;"/>

    <!-- Settings area -->
    <VBox spacing="18" style="-fx-padding: 20 24 20 24;">

        <!-- Max Price -->
        <VBox spacing="6">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Max Price" textFill="#7ecfff">
                    <font><Font name="Press Start 2P" size="8.0"/></font>
                </Label>
                <Label text="(&#x20AB;)" textFill="#555f6e">
                    <font><Font name="Press Start 2P" size="7.0"/></font>
                </Label>
            </HBox>
            <TextField fx:id="maxPriceField"
                       promptText="Maximum amount you will bid..."
                       prefHeight="38.0"
                       stylesheets="@../css/style.css"/>
        </VBox>

        <!-- Bid Step -->
        <VBox spacing="6">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Bid Step" textFill="#7ecfff">
                    <font><Font name="Press Start 2P" size="8.0"/></font>
                </Label>
                <Label text="(&#x20AB;)" textFill="#555f6e">
                    <font><Font name="Press Start 2P" size="7.0"/></font>
                </Label>
            </HBox>
            <TextField fx:id="stepField"
                       promptText="Amount to raise each auto-bid..."
                       prefHeight="38.0"
                       stylesheets="@../css/style.css"/>
        </VBox>

        <!-- Anti-snipe info (read-only, server handles it automatically) -->
        <VBox spacing="8"
              style="-fx-border-color: #1a3a5c; -fx-border-radius: 8; -fx-background-color: #0a1628; -fx-background-radius: 8; -fx-padding: 14 16 14 16;">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="&#x23F0;" style="-fx-font-size: 14px;"/>
                <Label text="Anti-Snipe: ON" textFill="#00ff88">
                    <font><Font name="Press Start 2P" size="8.0"/></font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="AUTO"
                       style="-fx-background-color: #004d30; -fx-text-fill: #00ff88; -fx-padding: 2 6 2 6; -fx-background-radius: 4;">
                    <font><Font name="Press Start 2P" size="6.0"/></font>
                </Label>
            </HBox>
            <Label text="If a bid lands in the last 30s, the auction&#10;is automatically extended by 30s."
                   textFill="#7ecfff" wrapText="true"
                   style="-fx-font-size: 10px; -fx-padding: 0 0 0 4;"/>
        </VBox>

    </VBox>

    <!-- Message label -->
    <HBox alignment="CENTER" style="-fx-padding: 0 24 8 24;">
        <Label fx:id="msgLabel" text="" wrapText="true" maxWidth="432">
            <font><Font name="Press Start 2P" size="8.0"/></font>
        </Label>
    </HBox>

    <!-- Footer buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT"
          style="-fx-padding: 12 24 16 24; -fx-border-color: #1a3a5c; -fx-border-width: 1 0 0 0;">

        <Button fx:id="cancelAutoBidBtn" text="Cancel AutoBid"
                onAction="#handleCancelAutoBid" visible="false" managed="false"
                prefHeight="36" prefWidth="160"
                style="-fx-background-color: #3a1a1a; -fx-text-fill: #ff6b6b; -fx-border-color: #ff6b6b; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;">
            <font><Font name="Press Start 2P" size="7.0"/></font>
        </Button>

        <Button fx:id="activateBtn" text="&#x26A1;  Activate"
                onAction="#handleActivate"
                prefHeight="36" prefWidth="140"
                style="-fx-background-color: #00c96e; -fx-text-fill: #0a1628; -fx-border-color: transparent; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;">
            <font><Font name="Press Start 2P" size="8.0"/></font>
        </Button>
    </HBox>

</VBox>
