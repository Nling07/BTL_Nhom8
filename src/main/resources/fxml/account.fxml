<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="500.0" spacing="0" style="-fx-background-color: #0d1b2a; -fx-background-radius: 10; -fx-border-color: #1a3a5c; -fx-border-radius: 10; -fx-border-width: 1;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.btl.n8.Controller.AccounthomeController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" style="-fx-padding: 14 18 14 18; -fx-border-color: #1a3a5c; -fx-border-width: 0 0 1 0; -fx-background-color: #0a1628; -fx-background-radius: 10 10 0 0;">
        <Label text="My Account" textFill="#00ff88">
            <font><Font name="Press Start 2P" size="12.0" /></font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #00ff88; -fx-font-size: 16px; -fx-cursor: hand;" text="✕" />
    </HBox>

    <!-- Body -->
    <VBox spacing="0" style="-fx-padding: 20 18 20 18;">

        <!-- Avatar + Info row -->
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 0 0 16 0; -fx-border-color: #1a3a5c; -fx-border-width: 0 0 1 0;">
            <Label fx:id="avatarLabel" style="-fx-background-color: #1a3a5c; -fx-text-fill: #00ff88; -fx-background-radius: 30; -fx-min-width: 60; -fx-min-height: 60; -fx-max-width: 60; -fx-max-height: 60; -fx-alignment: center; -fx-border-color: #00ff88; -fx-border-radius: 30; -fx-border-width: 2;" text="??">
                <font><Font name="Press Start 2P" size="13.0" /></font>
            </Label>
            <VBox spacing="8">
                <Label fx:id="usernameLabel" text="-" textFill="#ffd700">
                    <font><Font name="Press Start 2P" size="11.0" /></font>
                </Label>
                <Label fx:id="roleLabel" style="-fx-background-color: #1a3a5c; -fx-text-fill: #7ecfff; -fx-padding: 3 10 3 10; -fx-background-radius: 99;" text="-">
                    <font><Font name="Press Start 2P" size="8.0" /></font>
                </Label>
            </VBox>
        </HBox>

        <!-- ID -->
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 0 10 0; -fx-border-color: #112240; -fx-border-width: 0 0 1 0;">
            <Label minWidth="70" text="ID" textFill="#7ecfff">
                <font><Font name="Press Start 2P" size="8.0" /></font>
            </Label>
            <Label fx:id="idLabel" text="-" textFill="#ffffff">
                <font><Font name="Press Start 2P" size="9.0" /></font>
            </Label>
        </HBox>

        <!-- Username -->
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 0 10 0; -fx-border-color: #112240; -fx-border-width: 0 0 1 0;">
            <Label minWidth="70" text="Username" textFill="#7ecfff">
                <font><Font name="Press Start 2P" size="8.0" /></font>
            </Label>
            <Label fx:id="usernameLabel2" text="-" textFill="#ffffff">
                <font><Font name="Press Start 2P" size="9.0" /></font>
            </Label>
        </HBox>

        <!-- Role -->
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 0 10 0;">
            <Label minWidth="70" text="Role" textFill="#7ecfff">
                <font><Font name="Press Start 2P" size="8.0" /></font>
            </Label>
            <Label fx:id="roleLabel2" text="-" textFill="#ffffff">
                <font><Font name="Press Start 2P" size="9.0" /></font>
            </Label>
        </HBox>

        <!-- Bid history title -->
        <Label style="-fx-padding: 16 0 10 0; -fx-border-color: #1a3a5c; -fx-border-width: 1 0 0 0;" text="Bid history" textFill="#00ff88">
            <font><Font name="Press Start 2P" size="9.0" /></font>
        </Label>

        <!-- Bid history table -->
        <TableView fx:id="bidTable" prefHeight="200.0" stylesheets="@../css/style.css">
            <columns>
                <TableColumn fx:id="colItem" prefWidth="160.0" text="Item" />
                <TableColumn fx:id="colAmount" prefWidth="110.0" text="Amount" />
                <TableColumn fx:id="colTime" prefWidth="95.20001220703125" text="Time" />
                <TableColumn fx:id="colStatus" prefWidth="89.60003662109375" text="Status" />
            </columns>
        </TableView>

    </VBox>
</VBox>
